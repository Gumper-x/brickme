{
  "name": "@brickflow/prettier",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Shared Prettier config for brickflow workspaces.",
  "files": [
    "index.js"
  ],
  "exports": "./index.js",
  "scripts": {
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --ignore-path ../../.prettierignore --write",
    "format:check": "pnpm exec prettier . --ignore-path ../../.prettierignore --check"
  },
  "peerDependencies": {
    "prettier": ">=3"
  },
  "author": "",
  "license": "ISC"
}
