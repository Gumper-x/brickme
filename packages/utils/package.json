{
  "name": "@brickflow/utils",
  "version": "0.0.5",
  "type": "module",
  "description": "Shared utility helpers for brickflow packages.",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "rolldown -c build.config.ts",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "pnpm typecheck && eslint -v && NODE_ENV=deploy eslint --cache .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --ignore-path ../../.prettierignore --write",
    "format:check": "pnpm exec prettier . --ignore-path ../../.prettierignore --check"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@brickflow/lint": "workspace:*",
    "@brickflow/prettier": "workspace:*",
    "rolldown": "1.0.2",
    "rolldown-plugin-dts": "0.25.1"
  },
  "author": "",
  "license": "ISC"
}
