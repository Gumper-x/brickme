{
  "name": "@brickflow/cli",
  "version": "0.0.8",
  "description": "",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "brick": "./index.mjs"
  },
  "scripts": {
    "latest": "node ./index.mjs latest",
    "lint": "pnpm run --if-present typecheck && eslint -v && NODE_ENV=deploy eslint --cache .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --ignore-path ../../.prettierignore --write",
    "format:check": "pnpm exec prettier . --ignore-path ../../.prettierignore --check"
  },
  "dependencies": {
    "@babel/parser": "7.29.7",
    "@babel/traverse": "7.29.7",
    "@babel/types": "7.29.7",
    "@google/genai": "2.6.0",
    "@vue/compiler-sfc": "3.5.35",
    "fantasticon": "4.1.0",
    "glob": "13.0.6",
    "looks-same": "10.0.1",
    "sharp": "0.34.5",
    "svgo": "4.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@brickflow/lint": "workspace:*",
    "@brickflow/prettier": "workspace:*"
  },
