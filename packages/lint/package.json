{
  "name": "@brickflow/lint",
  "version": "0.0.5",
  "type": "module",
  "description": "Shared ESLint configs for brickflow workspaces.",
  "files": [
    "index.cjs",
    "index.js",
    "nuxt.cjs",
    "nuxt.js",
    "shared.js",
    "brick.js",
    "rules"
  ],
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    },
    "./nuxt": {
      "import": "./nuxt.js",
      "require": "./nuxt.cjs",
      "default": "./nuxt.js"
    }
  },
  "scripts": {
    "lint": "pnpm run --if-present typecheck && eslint -v && NODE_ENV=deploy eslint --cache .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier . --ignore-path ../../.prettierignore --write",
    "format:check": "pnpm exec prettier . --ignore-path ../../.prettierignore --check"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "typescript-eslint": "8.59.4",
    "vue-eslint-parser": "10.4.0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3"
  },
  "author": "",
  "license": "ISC"
}
