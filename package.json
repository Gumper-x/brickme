{
  "name": "brickflow",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev:doc": "pnpm --filter doc dev --host",
    "dev:playground": "pnpm --filter playground dev --host",
    "dev:ui": "pnpm dev:playground",
    "build": "pnpm --recursive --filter \"./packages/**\" --if-present build",
    "typecheck": "pnpm --recursive --filter \"./packages/**\" --filter \"./apps/**\" typecheck",
    "test": "pnpm --filter playground test",
    "pack:update": "changeset && changeset version",
    "pack:version": "changeset version",
    "pack:publish": "pnpm build && node ./scripts/publish-packages.mjs",
    "pack:publish:dry": "pnpm build && node ./scripts/publish-packages.mjs --dry-run",
    "lint:fix": "pnpm --filter \"./apps/**\" --filter \"./packages/**\" --parallel --stream lint:fix",
    "lint": "pnpm --filter \"./apps/**\" --filter \"./packages/**\" --parallel --stream lint",
    "format": "pnpm --filter \"./apps/**\" --filter \"./packages/**\" --parallel --stream format",
    "format:check": "pnpm --filter \"./apps/**\" --filter \"./packages/**\" --parallel --stream format:check",
    "clear": "rm -rf node_modules pnpm-lock.yaml package-lock.json **/**/.nuxt **/**/node_modules **/**/pnpm-lock.yaml **/**/package-lock.json **/**/dist **/**/.DS_Store"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "author": "",
  "license": "ISC",
  "description": ""
}
